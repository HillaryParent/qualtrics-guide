do not reside in the United States"},"QuestionJS":"(function() {\n\tvar observer;\n\n\tQualtrics.SurveyEngine.addOnload(function()\n\t{\n\t\t\/*Place your JavaScript here to run when the page loads*\/\n\t\tvar that = this;\n\t\tvar observerTarget = this.getQuestionContainer().querySelector(\".select-menu span.rich-text\");\n\t\t\n\t\tvar pageContainer = document.querySelector(\".questions-container\");\n\n\t\tvar callback = (mutationList) => {\n\t\t\tfor (const mutation of mutationList) {\n\t\t\t\tif (mutation.type === \"childList\") {\n\t\t\t\t\tif(mutation.target.innerText != \"Select one\") {\n\t\t\t\t\t\tvar choices = Array.from(pageContainer.querySelectorAll(\".question.mc:is(.horizontal, .vertical):not(.hidden)\"));\n\t\t\t\t\t\tvar dropdowns = Array.from(pageContainer.querySelectorAll(\".question.mc.dropdown:not(.hidden) ul\"));\n\t\t\t\t\t\tvar radioGroups = Array.from(pageContainer.querySelectorAll(\".question.matrix.table div[role='radiogroup']:not(.hidden)\"));\n\t\t\t\t\t\tvar inputs = Array.from(pageContainer.querySelectorAll(\".question.te:not(.hidden) .text-input\"));\n\t\t\t\t\t\tif (choices.every(q => q.querySelector(\"span.selected\")) && \n\t\t\t\t\t\t\tdropdowns.every(q => q.querySelector(\"li:not(:first-child).selected\")) &&\n\t\t\t\t\t\t\tradioGroups.every(group => group.querySelector(\"span.selected\")) && \n\t\t\t\t\t\t\tinputs.every(q => q.value != \"\")) {\n\t\t\t\t\t\t\tthat.clickNextButton();\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t};\n\t\tobserver = new MutationObserver(callback);\n\t\tobserver.observe(observerTarget, { childList: true });\n\n\t});\n\n\tQualtrics.SurveyEngine.addOnReady(function()\n\t{\n\t\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n\t});\n\n\tQualtrics.SurveyEngine.addOnUnload(function()\n\t{\n\t\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\t\tobserver.disconnect();\n\t});\n})();"}},{"SurveyID":"SV_1ZCKS9W3hi9v9CC","Element":"SQ","PrimaryAttribute":"