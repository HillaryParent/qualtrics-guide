lement":"SQ","PrimaryAttribute":"QID29","SecondaryAttribute":"If you have any feedback for us, please enter it here.","TertiaryAttribute":null,"Payload":{"QuestionText":"If you have any feedback for us, please enter it here.","DefaultChoices":false,"DataExportTag":"comments.feedback","QuestionType":"TE","Selector":"ESTB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If you have any feedback for us, please enter it here.","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID29"}},{"SurveyID":"SV_1ZCKS9W3hi9v9CC","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"In which of these grades are students about 5 years old?","TertiaryAttribute":null,"Payload":{"QuestionText":"In which of these grades are students about 5 years old?","DefaultChoices":false,"DataExportTag":"screeners.kinder","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In which of these grades are students about 5 years old?","Choices":{"1":{"Display":"Kindergarten"},"2":{"Display":"Third grade"},"3":{"Display":"Fifth grade"},"4":{"Display":"Seventh grade"},"5":{"Display":"Ninth grade"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID3","QuestionJS":"(function() {\n\t\/\/ global variables\n\tvar container; \/\/ question container\n\tvar handleChange; \/\/ function to handle change event\n\t\n\tQualtrics.SurveyEngine.addOnload(function()\n\t{\n\t\t\/*Place your JavaScript here to run when the page loads*\/\n\t\tvar that = this;\n\t\t\n\t\tcontainer = that.getQuestionContainer();\n\t\t\n\t\tvar radioGroups = Array.from(container.querySelectorAll(\"div[role='radiogroup']\"));\n\t\tvar idRegex = RegExp(\"^\" + that.questionId + \"(?:-|$)\");\n\t\n\t\t\/\/ listens for radio buttons to be selected (i.e., \"change\" event)\n\t\t\/\/ immediately submits the page if an option has been selected\n\t\n\t\thandleChange = (event) => {\n\t\t\tif(event.target && [\"checkbox\",\"radio\"].includes(event.target.type) && event.target.name.match(idRegex)) {\n\t\t\t\tif (radioGroups.every(group => group.querySelector(\"span.selected\"))) {\n\t\t\t\t\tthat.clickNextButton();\n\t\t\t\t}\n\t\t\t}\n\t\t};\n\t\tcontainer.addEventListener(\"change\", handleChange);\n\t\t\n\t});\n\t\t\n\t\t\n\tQualtrics.SurveyEngine.addOnReady(function()\n\t{\n\t\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\t\t\n\t});\n\t\n\tQualtrics.SurveyEngine.addOnUnload(function()\n\t{\n\t\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\t\t\/\/ remove the listener\n\t\tif (container && handleChange) {\n\t\t\tcontainer.removeEventListener(\"change\", handleChange);\n\t\t}\n\t});\n})();","RecodeValues":{"1":"1","2":"3","3":"5","4":"7","5":"9"},"VariableNaming":{"1":"Kindergarten","2":"Third","3":"Fifth","4":"Seventh","5":"Ninth"},"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"}}},{"SurveyID":"SV_1ZCKS9W3hi9v9CC","Element":"SQ","PrimaryAttribute":"QID30","SecondaryAttribute":"If you had any technical issues with the survey, please let us know here.","TertiaryAttribute":null,"Payload":{"QuestionText":"If you had any technical issues with the survey, please let us know here.","DefaultChoices":false,"DataExportTag":"comments.issues","QuestionType":"TE","Selector":"ESTB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If you had any technical issues with the survey, please let us know here.","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[