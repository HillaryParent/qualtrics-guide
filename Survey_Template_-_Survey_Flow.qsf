(.hidden) .text-input\"));\n\t\t\t\t\t\tif (choices.every(q => q.querySelector(\"span.selected\")) && \n\t\t\t\t\t\t\tdropdowns.every(q => q.querySelector(\"li:not(:first-child).selected\")) &&\n\t\t\t\t\t\t\tradioGroups.every(group => group.querySelector(\"span.selected\")) && \n\t\t\t\t\t\t\tinputs.every(q => q.value != \"\")) {\n\t\t\t\t\t\t\tthat.clickNextButton();\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t};\n\t\tobserver = new MutationObserver(callback);\n\t\tobserver.observe(observerTarget, { childList: true });\n\n\t});\n\n\tQualtrics.SurveyEngine.addOnReady(function()\n\t{\n\t\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n\t});\n\n\tQualtrics.SurveyEngine.addOnUnload(function()\n\t{\n\t\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\t\tobserver.disconnect();\n\t});\n})();"}},{"SurveyID":"SV_1ZCKS9W3hi9v9CC","Element":"SQ","PrimaryAttribute":"QID19","SecondaryAttribute":"Are you currently married?","TertiaryAttribute":null,"Payload":{"QuestionText":"Are you currently married?","DefaultChoices":false,"DataExportTag":"demos.married","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Are you currently married?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID19","RecodeValues":{"1":"1","2":"0"},"VariableNaming":{"1":"Yes","2":"No"}}},{"SurveyID":"SV_1ZCKS9W3hi9v9CC","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"consent.rt","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Confi